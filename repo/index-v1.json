{"repo": {"timestamp": 1774184760000, "version": 20002, "name": "TroyJ Android Apps", "icon": "icon.png", "address": "https://troyj.github.io/fdroid/repo", "description": "Signed release builds for TroyJ Android apps"}, "requests": {"install": [], "uninstall": []}, "apps": [{"categories": ["navigation"], "suggestedVersionCode": "1", "license": "Unknown", "name": "GPS Sim", "added": 1774155602000, "packageName": "com.prado.gpssim", "lastUpdated": 1774155602000, "localized": {"en-US": {"description": "GPS Sim provides a simple test harness for replaying location data during Prado development and field validation.\n", "name": "GPS Sim", "summary": "HTTP-driven GPS playback for Prado testing", "whatsNew": "Initial F-Droid release.\n\nPublished: 2026-03-22 15:59 AEDT\n"}}}, {"authorName": "TroyJ", "categories": ["audio"], "suggestedVersionCode": "4", "issueTracker": "https://github.com/TroyJ/swift-whisper/issues", "license": "Unknown", "name": "Swift Whisper", "sourceCode": "https://github.com/TroyJ/swift-whisper", "summary": "Whisper speech recognition benchmark with Vulkan GPU acceleration", "added": 1774168326000, "packageName": "com.troyj.swiftwhisperandroidapp", "lastUpdated": 1774184760000, "localized": {"en-US": {"description": "Swift Whisper Android is a benchmark and test harness for whisper.cpp speech recognition on Android devices. It downloads whisper models on first launch and runs transcription benchmarks using Vulkan GPU acceleration on supported hardware.\n\nFeatures:\n- Vulkan GPU-accelerated inference on physical ARM64 devices\n- Automatic model download with progress (tiny.en, large-v3-turbo-q5_0)\n- Per-iteration benchmark timing with live progress display\n- Correct JFK transcript verification against expected output\n- CPU fallback on emulators (MoltenVK detected and skipped)\n\nBuilt with Swift for Android via swift-whisper, a cross-platform SwiftPM wrapper around whisper.cpp.", "name": "Swift Whisper", "summary": "Whisper speech recognition benchmark for Android with Vulkan GPU acceleration", "whatsNew": "Added real GPU backend detection. Fixed accumulating benchmark output. SHA-1 model verification. Per-iteration progress display.\n\nPublished: 2026-03-23 00:05 AEDT\n"}}}, {"categories": ["fdroid"], "suggestedVersionCode": "73", "license": "Unknown", "name": "Tree Viewer", "added": 1772857736000, "packageName": "com.prado.treeviewer", "lastUpdated": 1774178996000, "localized": {"en-US": {"description": "Tree Viewer is a developer tool that uses Android's AccessibilityService to display the UI tree of the current screen as a live overlay.\n\nFeatures:\n- Left-half overlay showing the full accessibility tree with indentation\n- Tags for clickable, editable, scrollable, and long-clickable elements\n- Text content and content descriptions displayed inline\n- Right-half overlay with interactive blocks for clickable elements\n- Blocks show color-coded action availability (click/long-click)\n- Page up/down navigation for the log view\n- Show/hide toggle for the right-side overlay\n- Pass-through touch on the log overlay (taps reach the app underneath)\n- Auto-refreshes on screen content changes with debounce\n\nPermissions:\n- Draw over other apps (SYSTEM_ALERT_WINDOW) \u2014 for the overlay display\n- Accessibility Service \u2014 to read the UI tree\n\nThis app is intended for developers and accessibility testers. It does not collect, store, or transmit any data.\n", "name": "Tree Viewer", "summary": "v1.073 - Live overlay of the Android accessibility tree for debugging.", "whatsNew": "Updated Prado Tree Viewer release with current app, bridge server, and tooling changes.\n\nPublished: 2026-03-22 22:40 AEDT\n"}}}], "packages": {"com.prado.gpssim": [{"added": 1774155602000, "apkName": "com.prado.gpssim-v1.apk", "hash": "88e8afbdce57197e826679997fcfe96451f87b4efa4c279ddc4be7201a8228fe", "hashType": "sha256", "minSdkVersion": 26, "packageName": "com.prado.gpssim", "sig": "63ad5bf8645b201a8c600594fbd148be", "signer":