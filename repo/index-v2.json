W"}, {"name": "android.permission.INTERNET"}, {"name": "android.permission.RECORD_AUDIO"}, {"name": "android.permission.MODIFY_AUDIO_SETTINGS"}, {"name": "android.permission.MEDIA_CONTENT_CONTROL"}, {"name": "android.permission.MODIFY_AUDIO_ROUTING"}, {"name": "android.permission.QUERY_AUDIO_STATE"}, {"name": "android.permission.POST_NOTIFICATIONS"}, {"name": "android.permission.ACCESS_NOTIFICATION_POLICY"}, {"name": "android.permission.BLUETOOTH_CONNECT"}, {"name": "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"}, {"name": "android.permission.REQUEST_INSTALL_PACKAGES"}, {"name": "android.permission.MANAGE_EXTERNAL_STORAGE"}, {"name": "com.prado.treeviewer.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}}}, "com.troyj.swiftwhisperandroidapp": {"metadata": {"added": 1774168326000, "categories": ["audio"], "issueTracker": "https://github.com/TroyJ/swift-whisper/issues", "lastUpdated": 1774184760000, "sourceCode": "https://github.com/TroyJ/swift-whisper", "authorName": "TroyJ", "name": {"en-US": "Swift Whisper"}, "summary": {"en-US": "Whisper speech recognition benchmark with Vulkan GPU acceleration"}, "description": {"en-US": "Swift Whisper Android is a benchmark and test harness for whisper.cpp speech recognition on Android devices. It downloads whisper models on first launch and runs transcription benchmarks using Vulkan GPU acceleration on supported hardware.\n\nFeatures:\n- Vulkan GPU-accelerated inference on physical ARM64 devices\n- Automatic model download with progress (tiny.en, large-v3-turbo-q5_0)\n- Per-iteration benchmark timing with live progress display\n- Correct JFK transcript verification against expected output\n- CPU fallback on emulators (MoltenVK detected and skipped)\n\nBuilt with Swift for Android via swift-whisper, a cross-platform SwiftPM wrapper around whisper.cpp."}, "preferredSigner": "f09a1aa4d481e07e0355e0bcad3fb92c0e34654c2eafc476c9ebf2ea69c3465c"}, "versions": {"10833f8082db5c6135bd5eaffca4748522f4c5f2451f1738ce5ea8e758c45a9a": {